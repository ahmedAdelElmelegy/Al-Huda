{
    "wisdoms": [
        {
            "id": 1,
            "text": "من جد وجد، ومن زرع حصد",
            "source": "حكمة عربية"
        },
        {
            "id": 2,
            "text": "العلم نور والجهل ظلام",
            "source": "حكمة عربية"
        },
        {
            "id": 3,
            "text": "الصبر مفتاح الفرج",
            "source": "حكمة عربية"
        },
        {
            "id": 4,
            "text": "إذا أردت أن تطاع فأمر بما يستطاع",
            "source": "حكمة عربية"
        },
        {
            "id": 5,
            "text": "رب أخ لك لم تلده أمك",
            "source": "حكمة عربية"
        },
        {
            "id": 6,
            "text": "الوقت كالسيف إن لم تقطعه قطعك",
            "source": "حكمة عربية"
        },
        {
            "id": 7,
            "text": "من راقب الناس مات هماً",
            "source": "حكمة عربية"
        },
        {
            "id": 8,
            "text": "لا تؤجل عمل اليوم إلى الغد",
            "source": "حكمة عربية"
        },
        {
            "id": 9,
            "text": "العقل السليم في الجسم السليم",
            "source": "حكمة يونانية"
        },
        {
            "id": 10,
            "text": "الكتاب خير جليس في الأنام",
            "source": "المتنبي"
        },
        {
            "id": 11,
            "text": "إن الله لا يغير ما بقوم حتى يغيروا ما بأنفسهم",
            "source": "القرآن الكريم"
        },
        {
            "id": 12,
            "text": "وما توفيقي إلا بالله عليه توكلت وإليه أنيب",
            "source": "القرآن الكريم"
        },
        {
            "id": 13,
            "text": "إنما الأعمال بالنيات",
            "source": "حديث شريف"
        },
        {
            "id": 14,
            "text": "خيركم من تعلم القرآن وعلمه",
            "source": "حديث شريف"
        },
        {
            "id": 15,
            "text": "الكلمة الطيبة صدقة",
            "source": "حديث شريف"
        },
        {
            "id": 16,
            "text": "تبسمك في وجه أخيك صدقة",
            "source": "حديث شريف"
        },
        {
            "id": 17,
            "text": "من سلك طريقاً يلتمس فيه علماً سهل الله له به طريقاً إلى الجنة",
            "source": "حديث شريف"
        },
        {
            "id": 18,
            "text": "المؤمن القوي خير وأحب إلى الله من المؤمن الضعيف",
            "source": "حديث شريف"
        },
        {
            "id": 19,
            "text": "لا يؤمن أحدكم حتى يحب لأخيه ما يحب لنفسه",
            "source": "حديث شريف"
        },
        {
            "id": 20,
            "text": "من كان يؤمن بالله واليوم الآخر فليقل خيراً أو ليصمت",
            "source": "حديث شريف"
        },
        {
            "id": 21,
            "text": "اطلبوا العلم من المهد إلى اللحد",
            "source": "حكمة"
        },
        {
            "id": 22,
            "text": "التواضع يرفع والكبر يضع",
            "source": "حكمة عربية"
        },
        {
            "id": 23,
            "text": "الصديق وقت الضيق",
            "source": "حكمة عربية"
        },
        {
            "id": 24,
            "text": "قليل دائم خير من كثير منقطع",
            "source": "حكمة"
        },
        {
            "id": 25,
            "text": "اليد العليا خير من اليد السفلى",
            "source": "حديث شريف"
        },
        {
            "id": 26,
            "text": "خير الأمور أوسطها",
            "source": "حكمة عربية"
        },
        {
            "id": 27,
            "text": "لكل داء دواء",
            "source": "حديث شريف"
        },
        {
            "id": 28,
            "text": "المرء مخبوء تحت لسانه",
            "source": "الإمام علي"
        },
        {
            "id": 29,
            "text": "الناس معادن كمعادن الذهب والفضة",
            "source": "حديث شريف"
        },
        {
            "id": 30,
            "text": "ما خاب من استخار ولا ندم من استشار",
            "source": "حكمة"
        }
    ]
}